# ── 本番環境用 .env ──
# docker-compose.prod.yml で使用
# cp .env.example .env.prod して値を変更

ENVIRONMENT=production
APP_TITLE=予約管理システム

# ── データベース ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=reservation
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_STRONG_PASSWORD@localhost:5432/reservation

# ── セキュリティ（必須: 下記コマンドで生成） ──
# openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# 初回セットアップ後、管理画面から変更
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ── CORS ──
# 本番ドメイン例: https://yoyaku.example.com
# Render でフロントとAPIが別ドメインの場合:
# CORS_ORIGINS=https://your-frontend.onrender.com
# CHATBOT_ALLOWED_ORIGINS=https://your-embed-site.com,https://www.your-embed-site.com
CORS_ORIGINS=
CHATBOT_ALLOWED_ORIGINS=

# ── AI / 外部API ──
GEMINI_API_KEY=AI........................
GEMINI_MODEL=gemini-2.5-flash

# ── LINE連携 ──
LINE_CHANNEL_SECRET=dc.........................
LINE_CHANNEL_ACCESS_TOKEN=Viv................................
LINE_ADMIN_USER_ID=Ud..................................


# ── メール取得 ──
MAIL_PROVIDER=icloud-imap
# icloud-imap 利用時は必須（Renderサービス移設時に漏れやすいので要注意）
ICLOUD_EMAIL=your_apple_id@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
IMAP_HOST=imap.mail.me.com
IMAP_PORT=993
IMAP_MAILBOX=INBOX
HOTPEPPER_SENDER_FILTERS=yoyaku_system@salonboard.com


# システム異常(SOS)通知の送信先（開発者）
ADMIN_LINE_DEVELOPER_USER_ID=U.........................
LINE_CHANNEL_DEVELOPER_ACCESS_TOKEN=Viv..............................